<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.focus.controller.ProfileController"
            styleClass="root-pane">

    <center>
        <ScrollPane fitToWidth="true"
                    styleClass="main-scroll">
            <VBox spacing="30"
                  styleClass="profile-wrapper">

                <HBox spacing="25"
                      alignment="CENTER_LEFT"
                      styleClass="profile-header">
                    <StackPane styleClass="avatar-box">
                        <Label fx:id="avatarLabel"
                               styleClass="avatar-label"
                               text="👤"/>
                    </StackPane>
                    <VBox spacing="8">
                        <Label fx:id="usernameLabel"
                               styleClass="profile-name"/>
                        <Label fx:id="emailLabel"
                               styleClass="profile-email"/>
                        <HBox spacing="10">
                            <Button text="✏️ Редактировать"
                                    styleClass="edit-btn"
                                    onAction="#editProfile"/>
                            <Button text="🚪 Выйти"
                                    styleClass="logout-btn"
                                    onAction="#logout"/>
                        </HBox>
                    </VBox>
                </HBox>

                <HBox spacing="20"
                      styleClass="stats-box"
                      alignment="CENTER">
                    <VBox alignment="CENTER"
                          styleClass="stat-card"
                          spacing="5">
                        <Label fx:id="watchedCount"
                               styleClass="stat-number"
                               text="0"/>
                        <Label text="Просмотрено"
                               styleClass="stat-label"/>
                    </VBox>
                    <VBox alignment="CENTER"
                          styleClass="stat-card"
                          spacing="5">
                        <Label fx:id="favoritesCount"
                               styleClass="stat-number"
                               text="0"/>
                        <Label text="В списке"
                               styleClass="stat-label"/>
                    </VBox>
                </HBox>

                <VBox spacing="12" styleClass="section">
                    <Label text="❤️ Моё избранное"
                           styleClass="section-title"/>
                    <ScrollPane styleClass="h-scroll"
                                fitToHeight="true">
                        <HBox fx:id="favoritesRow"
                              spacing="12"
                              styleClass="movie-row"/>
                    </ScrollPane>
                </VBox>

                <VBox spacing="12" styleClass="section">
                    <Label text="🕐 История просмотров"
                           styleClass="section-title"/>
                    <ScrollPane styleClass="h-scroll"
                                fitToHeight="true">
                        <HBox fx:id="historyRow"
                              spacing="12"
                              styleClass="movie-row"/>
                    </ScrollPane>
                </VBox>

                <VBox fx:id="editForm"
                      spacing="15"
                      styleClass="edit-form"
                      visible="false"
                      managed="false">
                    <Label text="Редактирование профиля"
                           styleClass="form-title"/>
                    <Label text="Имя пользователя"/>
                    <TextField fx:id="editUsername"
                               styleClass="login-field"/>
                    <Label text="Email"/>
                    <TextField fx:id="editEmail"
                               styleClass="login-field"/>
                    <Label text="Новый пароль"/>
                    <PasswordField fx:id="editPassword"
                                   styleClass="login-field"
                                   promptText="Оставьте пустым если не меняете"/>
                    <Label fx:id="editError"
                           styleClass="error-label"
                           text=""/>
                    <HBox spacing="10">
                        <Button text="💾 Сохранить"
                                styleClass="save-btn"
                                onAction="#saveProfile"/>
                        <Button text="Отмена"
                                styleClass="clear-btn"
                                onAction="#cancelEdit"/>
                    </HBox>
                </VBox>

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>