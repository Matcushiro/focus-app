<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.focus.controller.KidsController"
            styleClass="root-pane">

    <top>
        <VBox styleClass="catalog-top" spacing="15">
            <Label text="🧸 Детям"
                   styleClass="catalog-title"/>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true"
                    styleClass="main-scroll">
            <FlowPane fx:id="moviesGrid"
                      styleClass="movies-grid"
                      hgap="15" vgap="15"/>
        </ScrollPane>
    </center>

</BorderPane>