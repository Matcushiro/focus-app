<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.focus.controller.AdminPanelController"
            styleClass="root-pane">

    <top>
        <HBox styleClass="admin-panel-header"
              alignment="CENTER_LEFT"
              spacing="20">
            <Label text="⚙️ Панель администратора"
                   styleClass="admin-panel-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="adminNameLabel"
                   styleClass="filter-label"/>
        </HBox>
    </top>

    <center>
        <TabPane styleClass="admin-tabs">

            <!-- Вкладка: Фильмы -->
            <Tab text="🎬 Фильмы" closable="false">
                <fx:include source="admin.fxml"/>
            </Tab>

            <!-- Вкладка: Пользователи -->
            <Tab text="👥 Пользователи" closable="false">
                <BorderPane styleClass="root-pane">
                    <top>
                        <HBox styleClass="catalog-top"
                              spacing="15"
                              alignment="CENTER_LEFT">
                            <Label text="Всего пользователей:"
                                   styleClass="filter-label"/>
                            <Label fx:id="totalUsersLabel"
                                   styleClass="section-title"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button text="🔄 Обновить"
                                    styleClass="filter-btn"
                                    onAction="#refreshUsers"/>
                        </HBox>
                    </top>
                    <center>
                        <VBox spacing="0">
                            <TableView fx:id="usersTable"
                                       VBox.vgrow="ALWAYS"
                                       styleClass="users-table">
                                <columns>
                                    <TableColumn fx:id="idCol"
                                                 text="ID"
                                                 prefWidth="50"/>
                                    <TableColumn fx:id="usernameCol"
                                                 text="Имя"
                                                 prefWidth="150"/>
                                    <TableColumn fx:id="emailCol"
                                                 text="Email"
                                                 prefWidth="200"/>
                                    <TableColumn fx:id="roleCol"
                                                 text="Роль"
                                                 prefWidth="100"/>
                                    <TableColumn fx:id="createdCol"
                                                 text="Дата регистрации"
                                                 prefWidth="160"/>
                                    <TableColumn fx:id="statusCol"
                                                 text="Статус"
                                                 prefWidth="100"/>
                                </columns>
                            </TableView>

                            <!-- Кнопки управления -->
                            <HBox spacing="10"
                                  styleClass="catalog-top"
                                  alignment="CENTER_LEFT">
                                <Button text="🚫 Забанить"
                                        styleClass="admin-btn-danger"
                                        onAction="#banUser"/>
                                <Button text="✅ Разбанить"
                                        styleClass="admin-btn"
                                        onAction="#unbanUser"/>
                                <Button text="👑 Сделать админом"
                                        styleClass="admin-btn"
                                        onAction="#makeAdmin"/>
                                <Button text="👤 Сделать юзером"
                                        styleClass="admin-btn"
                                        onAction="#makeUser"/>
                                <Button text="🗑️ Удалить"
                                        styleClass="admin-btn-danger"
                                        onAction="#deleteUser"/>
                            </HBox>
                        </VBox>
                    </center>
                </BorderPane>
            </Tab>

            <!-- Вкладка: Логи -->
            <Tab text="📋 Логи действий" closable="false">
                <BorderPane styleClass="root-pane">
                    <top>
                        <HBox styleClass="catalog-top"
                              spacing="15"
                              alignment="CENTER_LEFT">
                            <Label text="📋 История действий"
                                   styleClass="section-title"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button text="🔄 Обновить"
                                    styleClass="filter-btn"
                                    onAction="#refreshLogs"/>
                            <Button text="💾 Экспорт в файл"
                                    styleClass="admin-btn"
                                    onAction="#exportLogs"/>
                        </HBox>
                    </top>
                    <center>
                        <TableView fx:id="logsTable"
                                   styleClass="users-table">
                            <columns>
                                <TableColumn fx:id="logIdCol"
                                             text="ID"
                                             prefWidth="50"/>
                                <TableColumn fx:id="logTimeCol"
                                             text="Время"
                                             prefWidth="160"/>
                                <TableColumn fx:id="logUserCol"
                                             text="Пользователь"
                                             prefWidth="150"/>
                                <TableColumn fx:id="logActionCol"
                                             text="Действие"
                                             prefWidth="180"/>
                                <TableColumn fx:id="logDetailsCol"
                                             text="Детали"
                                             prefWidth="350"/>
                            </columns>
                        </TableView>
                    </center>
                </BorderPane>
            </Tab>

            <!-- Вкладка: Статистика -->
            <Tab text="📊 Статистика" closable="false">
                <ScrollPane fitToWidth="true"
                            styleClass="main-scroll">
                    <VBox spacing="20"
                          styleClass="profile-wrapper">

                        <Label text="📊 Общая статистика"
                               styleClass="catalog-title"/>

                        <HBox spacing="20">
                            <VBox styleClass="stat-card"
                                  alignment="CENTER"
                                  spacing="5"
                                  HBox.hgrow="ALWAYS">
                                <Label fx:id="totalMoviesLabel"
                                       styleClass="stat-number"
                                       text="0"/>
                                <Label text="Фильмов"
                                       styleClass="stat-label"/>
                            </VBox>
                            <VBox styleClass="stat-card"
                                  alignment="CENTER"
                                  spacing="5"
                                  HBox.hgrow="ALWAYS">
                                <Label fx:id="totalSeriesLabel"
                                       styleClass="stat-number"
                                       text="0"/>
                                <Label text="Сериалов"
                                       styleClass="stat-label"/>
                            </VBox>
                            <VBox styleClass="stat-card"
                                  alignment="CENTER"
                                  spacing="5"
                                  HBox.hgrow="ALWAYS">
                                <Label fx:id="totalUsersStatLabel"
                                       styleClass="stat-number"
                                       text="0"/>
                                <Label text="Пользователей"
                                       styleClass="stat-label"/>
                            </VBox>
                            <VBox styleClass="stat-card"
                                  alignment="CENTER"
                                  spacing="5"
                                  HBox.hgrow="ALWAYS">
                                <Label fx:id="totalLogsLabel"
                                       styleClass="stat-number"
                                       text="0"/>
                                <Label text="Действий"
                                       styleClass="stat-label"/>
                            </VBox>
                        </HBox>

                    </VBox>
                </ScrollPane>
            </Tab>

        </TabPane>
    </center>

</BorderPane>