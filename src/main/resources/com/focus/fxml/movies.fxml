<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.focus.controller.MoviesController"
      styleClass="content-page"
      spacing="0">

    <!-- ===== Заголовок страницы ===== -->
    <VBox styleClass="page-header" spacing="4">
        <Label text="🎬 Фильмы" styleClass="page-main-title"/>
        <Label text="Большой выбор отечественных и зарубежных фильмов" styleClass="page-subtitle"/>
    </VBox>

    <!-- ===== Строка поиска + кнопка фильтров ===== -->
    <HBox styleClass="search-bar-row" spacing="10" alignment="CENTER_LEFT">
        <HBox styleClass="search-input-box" HBox.hgrow="ALWAYS" spacing="0" alignment="CENTER_LEFT">
            <Label text="🔍" styleClass="search-icon-label"/>
            <TextField fx:id="searchField"
                       promptText="Поиск фильмов по названию, режиссёру, жанру..."
                       styleClass="search-input"
                       HBox.hgrow="ALWAYS"/>
        </HBox>
        <Button fx:id="filterBtn"
                text="🎛 Фильтры"
                styleClass="filter-btn"
                onAction="#openFilterPopup"/>
    </HBox>

    <!-- ===== Счётчик результатов ===== -->
    <HBox styleClass="results-row" alignment="CENTER_LEFT">
        <Label fx:id="resultsLabel" text="" styleClass="results-label"/>
    </HBox>

    <!-- ===== Сетка фильмов ===== -->
    <ScrollPane styleClass="grid-scroll" VBox.vgrow="ALWAYS" fitToWidth="true">
        <FlowPane fx:id="moviesGrid" styleClass="movies-grid"
                  hgap="14" vgap="16"/>
    </ScrollPane>
</VBox>
