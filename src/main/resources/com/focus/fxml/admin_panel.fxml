<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.focus.controller.AdminPanelController"
      styleClass="admin-page"
      spacing="0">

    <!-- ===== Шапка панели ===== -->
    <HBox styleClass="navbar" alignment="CENTER_LEFT" spacing="20">
        <Label text="⚙ FOCUS" styleClass="nav-logo"/>
        <Label text="Панель администратора" styleClass="admin-section-title" HBox.hgrow="ALWAYS"/>
        <Label fx:id="adminNameLabel" text="" styleClass="profile-btn"/>
    </HBox>

    <!-- ===== Статистика ===== -->
    <HBox spacing="16" style="-fx-padding: 16 24; -fx-background-color: #0a0a0a;">
        <VBox styleClass="stat-card" spacing="4" alignment="CENTER" prefWidth="140">
            <Label text="🎬" style="-fx-font-size: 22px;"/>
            <Label fx:id="totalMoviesLabel" text="0"
                   style="-fx-text-fill: #E65C00; -fx-font-size: 22px; -fx-font-weight: bold;"/>
            <Label text="Фильмов" style="-fx-text-fill: #777; -fx-font-size: 11px;"/>
        </VBox>
        <VBox styleClass="stat-card" spacing="4" alignment="CENTER" prefWidth="140">
            <Label text="📺" style="-fx-font-size: 22px;"/>
            <Label fx:id="totalSeriesLabel" text="0"
                   style="-fx-text-fill: #E65C00; -fx-font-size: 22px; -fx-font-weight: bold;"/>
            <Label text="Сериалов" style="-fx-text-fill: #777; -fx-font-size: 11px;"/>
        </VBox>
        <VBox styleClass="stat-card" spacing="4" alignment="CENTER" prefWidth="140">
            <Label text="👥" style="-fx-font-size: 22px;"/>
            <Label fx:id="totalUsersStatLabel" text="0"
                   style="-fx-text-fill: #E65C00; -fx-font-size: 22px; -fx-font-weight: bold;"/>
            <Label text="Пользователей" style="-fx-text-fill: #777; -fx-font-size: 11px;"/>
        </VBox>
        <VBox styleClass="stat-card" spacing="4" alignment="CENTER" prefWidth="140">
            <Label text="📋" style="-fx-font-size: 22px;"/>
            <Label fx:id="totalLogsLabel" text="0"
                   style="-fx-text-fill: #E65C00; -fx-font-size: 22px; -fx-font-weight: bold;"/>
            <Label text="Логов" style="-fx-text-fill: #777; -fx-font-size: 11px;"/>
        </VBox>
    </HBox>

    <!-- ===== Основной контент (разделён на 2 блока) ===== -->
    <SplitPane orientation="VERTICAL" VBox.vgrow="ALWAYS"
               style="-fx-background-color: #0f0f0f;">

        <!-- === Таблица пользователей === -->
        <VBox spacing="10" style="-fx-padding: 16 20; -fx-background-color: #0f0f0f;">

            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="👥 Пользователи" styleClass="admin-section-title" HBox.hgrow="ALWAYS"/>
                <Label fx:id="totalUsersLabel" text="0"
                       style="-fx-text-fill: #E65C00; -fx-font-weight: bold;"/>
                <Button text="🔄 Обновить" styleClass="admin-btn-secondary" onAction="#refreshUsers"/>
            </HBox>

            <TableView fx:id="usersTable" styleClass="admin-table" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="idCol"       text="ID"      prefWidth="50"/>
                    <TableColumn fx:id="usernameCol"  text="Логин"   prefWidth="140"/>
                    <TableColumn fx:id="contactCol"   text="Email / Телефон" prefWidth="220"/>
                    <TableColumn fx:id="roleCol"      text="Роль"    prefWidth="90"/>
                    <TableColumn fx:id="createdCol"   text="Создан"  prefWidth="160"/>
                    <TableColumn fx:id="statusCol"    text="Статус"  prefWidth="120"/>
                </columns>
            </TableView>

            <HBox spacing="8">
                <Button text="🚫 Забанить"    styleClass="admin-btn-danger"
                        onAction="#banUser"/>
                <Button text="✅ Разбанить"   styleClass="admin-btn-edit"
                        onAction="#unbanUser"/>
                <Button text="👑 → ADMIN"     styleClass="admin-btn-edit"
                        onAction="#makeAdmin"/>
                <Button text="👤 → USER"      styleClass="admin-btn-secondary"
                        onAction="#makeUser"/>
                <Button text="🗑 Удалить"     styleClass="admin-btn-danger"
                        onAction="#deleteUser"/>
            </HBox>
        </VBox>

        <!-- === Таблица логов === -->
        <VBox spacing="10" style="-fx-padding: 16 20; -fx-background-color: #0f0f0f;">

            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="📋 Логи действий" styleClass="admin-section-title" HBox.hgrow="ALWAYS"/>
                <Button text="🔄 Обновить"  styleClass="admin-btn-secondary" onAction="#refreshLogs"/>
                <Button text="💾 Экспорт"   styleClass="admin-btn-primary"   onAction="#exportLogs"/>
            </HBox>

            <TableView fx:id="logsTable" styleClass="admin-table" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="logIdCol"      text="ID"        prefWidth="55"/>
                    <TableColumn fx:id="logTimeCol"    text="Время"     prefWidth="160"/>
                    <TableColumn fx:id="logUserCol"    text="Пользователь" prefWidth="140"/>
                    <TableColumn fx:id="logActionCol"  text="Действие"  prefWidth="180"/>
                    <TableColumn fx:id="logDetailsCol" text="Детали"    prefWidth="300"/>
                </columns>
            </TableView>

        </VBox>

    </SplitPane>
</VBox>
