<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>

<ScrollPane fitToWidth="true"
            styleClass="main-scroll"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.focus.controller.SeriesController">

    <VBox styleClass="home-content" spacing="0">

        <VBox styleClass="search-hero-block" spacing="14">
            <Label text="📺 Сериалы" styleClass="page-hero-title"/>
            <Label text="Лучшие сериалы со всего мира" styleClass="page-hero-sub"/>
            <HBox spacing="12" alignment="CENTER_LEFT" styleClass="search-bar-hero">
                <HBox styleClass="search-input-wrapper" HBox.hgrow="ALWAYS">
                    <Label text="🔍" styleClass="search-icon-label"/>
                    <TextField fx:id="searchField"
                               promptText="Введите название, жанр или режиссёра..."
                               styleClass="search-input-hero"
                               HBox.hgrow="ALWAYS"/>
                </HBox>
                <Button fx:id="filterBtn"
                        text="🎛 Фильтры"
                        styleClass="filter-btn-hero"
                        onAction="#openFilterPopup"/>
                <Label fx:id="resultsLabel" styleClass="results-label"/>
            </HBox>
        </VBox>

        <VBox fx:id="seriesSectionsBox" styleClass="sections-wrapper" spacing="40">

            <VBox styleClass="section" spacing="15">
                <Label text="🆕 НОВЫЕ СЕРИАЛЫ" styleClass="section-title"/>
                <ScrollPane styleClass="h-scroll" fitToHeight="true">
                    <HBox fx:id="seriesLatestRow" spacing="12" styleClass="movie-row"/>
                </ScrollPane>
            </VBox>

            <VBox styleClass="section" spacing="15">
                <Label text="🔥 ПОПУЛЯРНЫЕ СЕРИАЛЫ" styleClass="section-title"/>
                <ScrollPane styleClass="h-scroll" fitToHeight="true">
                    <HBox fx:id="seriesPopularRow" spacing="12" styleClass="movie-row"/>
                </ScrollPane>
            </VBox>

            <VBox styleClass="section" spacing="15">
                <Label text="⭐ ТОП ПО РЕЙТИНГУ" styleClass="section-title"/>
                <ScrollPane styleClass="h-scroll" fitToHeight="true">
                    <HBox fx:id="seriesTopRatedRow" spacing="12" styleClass="movie-row"/>
                </ScrollPane>
            </VBox>

            <VBox styleClass="section" spacing="15">
                <Label text="🌙 ТУРЕЦКИЕ СЕРИАЛЫ" styleClass="section-title"/>
                <ScrollPane styleClass="h-scroll" fitToHeight="true">
                    <HBox fx:id="seriesTurkishRow" spacing="12" styleClass="movie-row"/>
                </ScrollPane>
            </VBox>

        </VBox>

        <VBox fx:id="seriesSearchSection" visible="false" managed="false"
              styleClass="sections-wrapper" spacing="15">
            <FlowPane fx:id="moviesGrid"
                      hgap="12" vgap="16"
                      styleClass="movies-grid"/>
        </VBox>

    </VBox>
</ScrollPane>
