<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.focus.controller.LoginController"
           styleClass="login-root">

    <!-- Фоновый градиент -->
    <VBox styleClass="login-bg" alignment="CENTER">

        <!-- Карточка -->
        <VBox styleClass="login-card" alignment="TOP_CENTER" maxWidth="420">

            <!-- Логотип -->
            <VBox alignment="CENTER" spacing="4" styleClass="login-logo-section">
                <Label text="▶ FOCUS" styleClass="login-logo"/>
                <Label text="Ваш персональный кинотеатр" styleClass="login-tagline"/>
            </VBox>

            <!-- Разделитель -->
            <Separator styleClass="login-separator"/>

            <!-- Вкладки -->
            <HBox styleClass="login-tabs" alignment="CENTER" spacing="0">
                <Button fx:id="loginTabBtn" text="Войти"
                        onAction="#showLogin"
                        styleClass="login-tab-active"
                        maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                <Button fx:id="regTabBtn" text="Регистрация"
                        onAction="#showRegister"
                        styleClass="login-tab"
                        maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
            </HBox>

            <!-- ===== ФОРМА ВХОДА ===== -->
            <VBox fx:id="loginForm" styleClass="login-form" spacing="14" visible="true" managed="true">

                <Label text="Добро пожаловать!" styleClass="login-form-title"/>
                <Label text="Войдите в свой аккаунт" styleClass="login-form-subtitle"/>

                <VBox spacing="6">
                    <Label text="Логин / E-mail / Телефон" styleClass="login-field-label"/>
                    <HBox styleClass="login-input-wrap" alignment="CENTER_LEFT" spacing="8">
                        <Label text="👤" styleClass="login-input-icon"/>
                        <TextField fx:id="loginIdentifier"
                                   promptText="Введите логин, e-mail или телефон"
                                   styleClass="login-input"
                                   HBox.hgrow="ALWAYS"/>
                    </HBox>
                </VBox>

                <VBox spacing="6">
                    <Label text="Пароль" styleClass="login-field-label"/>
                    <HBox styleClass="login-input-wrap" alignment="CENTER_LEFT" spacing="8">
                        <Label text="🔒" styleClass="login-input-icon"/>
                        <PasswordField fx:id="loginPassword"
                                       promptText="Введите пароль"
                                       styleClass="login-input"
                                       HBox.hgrow="ALWAYS"/>
                    </HBox>
                </VBox>

                <Label fx:id="loginError" styleClass="login-error" wrapText="true"/>

                <Button text="▶  Войти"
                        onAction="#login"
                        styleClass="login-btn-primary"
                        maxWidth="Infinity"/>

            </VBox>

            <!-- ===== ФОРМА РЕГИСТРАЦИИ ===== -->
            <VBox fx:id="registerForm" styleClass="login-form" spacing="14"
                  visible="false" managed="false">

                <Label text="Создать аккаунт" styleClass="login-form-title"/>
                <Label text="Заполните данные для регистрации" styleClass="login-form-subtitle"/>

                <VBox spacing="6">
                    <Label text="Имя пользователя" styleClass="login-field-label"/>
                    <HBox styleClass="login-input-wrap" alignment="CENTER_LEFT" spacing="8">
                        <Label text="👤" styleClass="login-input-icon"/>
                        <TextField fx:id="regUsername"
                                   promptText="Придумайте логин"
                                   styleClass="login-input"
                                   HBox.hgrow="ALWAYS"/>
                    </HBox>
                </VBox>

                <VBox spacing="4">
                    <Label text="E-mail или номер телефона" styleClass="login-field-label"/>
                    <HBox styleClass="login-input-wrap" alignment="CENTER_LEFT" spacing="8">
                        <Label text="📧" styleClass="login-input-icon"/>
                        <TextField fx:id="regEmailOrPhone"
                                   promptText="user@mail.ru или +79001234567"
                                   styleClass="login-input"
                                   HBox.hgrow="ALWAYS"/>
                    </HBox>
                    <Label fx:id="regHint"
                           text="Введите e-mail или номер телефона"
                           styleClass="login-hint"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="Пароль" styleClass="login-field-label"/>
                    <HBox styleClass="login-input-wrap" alignment="CENTER_LEFT" spacing="8">
                        <Label text="🔒" styleClass="login-input-icon"/>
                        <PasswordField fx:id="regPassword"
                                       promptText="Минимум 6 символов"
                                       styleClass="login-input"
                                       HBox.hgrow="ALWAYS"/>
                    </HBox>
                </VBox>

                <VBox spacing="6">
                    <Label text="Повторите пароль" styleClass="login-field-label"/>
                    <HBox styleClass="login-input-wrap" alignment="CENTER_LEFT" spacing="8">
                        <Label text="🔒" styleClass="login-input-icon"/>
                        <PasswordField fx:id="regPasswordConfirm"
                                       promptText="Повторите пароль"
                                       styleClass="login-input"
                                       HBox.hgrow="ALWAYS"/>
                    </HBox>
                </VBox>

                <Label fx:id="regError" styleClass="login-error" wrapText="true"/>

                <Button text="✅  Зарегистрироваться"
                        onAction="#register"
                        styleClass="login-btn-primary"
                        maxWidth="Infinity"/>

            </VBox>

            <!-- Подвал карточки -->
            <Label text="© 2025 Focus — Все права защищены"
                   styleClass="login-footer"/>

        </VBox>
    </VBox>
</StackPane>