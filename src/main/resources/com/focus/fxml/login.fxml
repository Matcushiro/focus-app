<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.focus.controller.LoginController"
           styleClass="login-root">

    <VBox alignment="CENTER" spacing="0">

        <!-- Логотип -->
        <Label text="FOCUS" styleClass="login-logo"/>
        <Label text="Кино, сериалы и многое другое" styleClass="login-tagline"/>

        <!-- Карточка форм -->
        <VBox styleClass="login-card" spacing="0" alignment="TOP_CENTER">

            <!-- Переключатели вкладок -->
            <HBox styleClass="tab-row" spacing="0">
                <Button fx:id="loginTabBtn" text="Вход"
                        styleClass="tab-btn-active"
                        onAction="#showLogin"
                        HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                <Button fx:id="regTabBtn" text="Регистрация"
                        styleClass="tab-btn"
                        onAction="#showRegister"
                        HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
            </HBox>

            <!-- ==================== ФОРМА ВХОДА ==================== -->
            <VBox fx:id="loginForm" styleClass="auth-form" spacing="14" alignment="TOP_CENTER">

                <Label text="Добро пожаловать!" styleClass="form-title"/>

                <VBox spacing="5">
                    <Label text="Логин, e-mail или телефон" styleClass="field-label"/>
                    <TextField fx:id="loginIdentifier"
                               promptText="Введите логин, email или +7..."
                               styleClass="auth-field"/>
                </VBox>

                <VBox spacing="5">
                    <Label text="Пароль" styleClass="field-label"/>
                    <PasswordField fx:id="loginPassword"
                                   promptText="Введите пароль"
                                   styleClass="auth-field"/>
                </VBox>

                <Label fx:id="loginError" text="" styleClass="error-label"/>

                <Button text="Войти" styleClass="auth-btn-primary"
                        onAction="#login" maxWidth="Infinity"/>

            </VBox>

            <!-- ==================== ФОРМА РЕГИСТРАЦИИ ==================== -->
            <VBox fx:id="registerForm" styleClass="auth-form" spacing="14"
                  alignment="TOP_CENTER" visible="false" managed="false">

                <Label text="Создать аккаунт" styleClass="form-title"/>

                <VBox spacing="5">
                    <Label text="Имя пользователя" styleClass="field-label"/>
                    <TextField fx:id="regUsername"
                               promptText="Придумайте логин"
                               styleClass="auth-field"/>
                </VBox>

                <VBox spacing="5">
                    <Label text="E-mail или номер телефона" styleClass="field-label"/>
                    <TextField fx:id="regEmailOrPhone"
                               promptText="user@mail.ru  или  +79001234567"
                               styleClass="auth-field"/>
                    <Label fx:id="regHint"
                           text="Введите e-mail (user@mail.ru) или номер телефона (+79001234567)"
                           styleClass="hint-label"/>
                </VBox>

                <VBox spacing="5">
                    <Label text="Пароль" styleClass="field-label"/>
                    <PasswordField fx:id="regPassword"
                                   promptText="Минимум 6 символов"
                                   styleClass="auth-field"/>
                </VBox>

                <VBox spacing="5">
                    <Label text="Подтвердите пароль" styleClass="field-label"/>
                    <PasswordField fx:id="regPasswordConfirm"
                                   promptText="Повторите пароль"
                                   styleClass="auth-field"/>
                </VBox>

                <Label fx:id="regError" text="" styleClass="error-label"/>

                <Button text="Зарегистрироваться" styleClass="auth-btn-primary"
                        onAction="#register" maxWidth="Infinity"/>

            </VBox>

        </VBox>
    </VBox>
</StackPane>
