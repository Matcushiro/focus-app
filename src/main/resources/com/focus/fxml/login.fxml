<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.focus.controller.LoginController"
            styleClass="root-pane">

    <center>
        <VBox alignment="CENTER"
              spacing="20"
              styleClass="login-box">

            <Label text="Focus"
                   styleClass="login-logo"/>

            <HBox alignment="CENTER" spacing="0">
                <Button fx:id="loginTabBtn"
                        text="Войти"
                        styleClass="tab-btn-active"
                        onAction="#showLogin"/>
                <Button fx:id="regTabBtn"
                        text="Регистрация"
                        styleClass="tab-btn"
                        onAction="#showRegister"/>
            </HBox>

            <VBox fx:id="loginForm"
                  spacing="15"
                  alignment="CENTER">
                <TextField fx:id="loginUsername"
                           promptText="Имя пользователя"
                           styleClass="login-field"
                           prefWidth="300"/>
                <PasswordField fx:id="loginPassword"
                               promptText="Пароль"
                               styleClass="login-field"
                               prefWidth="300"/>
                <Label fx:id="loginError"
                       styleClass="error-label"
                       text=""/>
                <Button text="Войти"
                        styleClass="login-btn"
                        prefWidth="300"
                        onAction="#login"/>
            </VBox>

            <VBox fx:id="registerForm"
                  spacing="15"
                  alignment="CENTER"
                  visible="false"
                  managed="false">
                <TextField fx:id="regUsername"
                           promptText="Имя пользователя"
                           styleClass="login-field"
                           prefWidth="300"/>
                <TextField fx:id="regEmail"
                           promptText="Email"
                           styleClass="login-field"
                           prefWidth="300"/>
                <PasswordField fx:id="regPassword"
                               promptText="Пароль"
                               styleClass="login-field"
                               prefWidth="300"/>
                <PasswordField fx:id="regPasswordConfirm"
                               promptText="Подтвердите пароль"
                               styleClass="login-field"
                               prefWidth="300"/>
                <Label fx:id="regError"
                       styleClass="error-label"
                       text=""/>
                <Button text="Зарегистрироваться"
                        styleClass="login-btn"
                        prefWidth="300"
                        onAction="#register"/>
            </VBox>

        </VBox>
    </center>

</BorderPane>