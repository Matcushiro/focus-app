<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>

<ScrollPane fitToWidth="true"
            styleClass="main-scroll"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.focus.controller.KidsController">

    <VBox styleClass="home-content" spacing="0">

        <VBox styleClass="search-hero-block" spacing="14">
            <Label text="👶 Детям" styleClass="page-hero-title"/>
            <Label text="Безопасный контент для маленьких зрителей" styleClass="page-hero-sub"/>
            <HBox spacing="12" alignment="CENTER_LEFT" styleClass="search-bar-hero">
                <HBox styleClass="search-input-wrapper" HBox.hgrow="ALWAYS">
                    <Label text="🔍" styleClass="search-icon-label"/>
                    <TextField fx:id="kidsSearchField"
                               promptText="Поиск в детском контенте..."
                               styleClass="search-input-hero"
                               HBox.hgrow="ALWAYS"/>
                </HBox>
                <Button fx:id="kidsFilterBtn"
                        text="🎛 Фильтры"
                        onAction="#openKidsFilterPopup"
                        styleClass="filter-btn-hero"/>
                <Label fx:id="kidsResultsLabel" styleClass="results-label"/>
            </HBox>
        </VBox>

        <VBox fx:id="kidsSearchSection" styleClass="sections-wrapper"
              visible="false" managed="false" spacing="15">
            <HBox alignment="CENTER_LEFT" spacing="12" styleClass="search-results-header">
                <Label fx:id="kidsResultsCountLabel" text="Найдено: 0" styleClass="search-count-label"/>
            </HBox>
            <FlowPane fx:id="kidsSearchGrid" hgap="12" vgap="16"
                      styleClass="movies-grid"/>
        </VBox>

        <VBox fx:id="kidsSectionsBox" styleClass="sections-wrapper" spacing="40">

            <VBox styleClass="section" spacing="15">
                <HBox alignment="CENTER_LEFT" spacing="8" styleClass="section-header-row">
                    <Label text="🎬" styleClass="section-icon"/>
                    <Label text="Все детское" styleClass="section-title"/>
                </HBox>
                <ScrollPane styleClass="h-scroll" hbarPolicy="AS_NEEDED" vbarPolicy="NEVER"
                            fitToHeight="true">
                    <HBox fx:id="kidsAllRow" styleClass="movie-row" spacing="12"/>
                </ScrollPane>
            </VBox>

            <VBox styleClass="section" spacing="15">
                <HBox alignment="CENTER_LEFT" spacing="8" styleClass="section-header-row">
                    <Label text="⭐" styleClass="section-icon"/>
                    <Label text="Рекомендуем" styleClass="section-title-orange"/>
                </HBox>
                <ScrollPane styleClass="h-scroll" hbarPolicy="AS_NEEDED" vbarPolicy="NEVER"
                            fitToHeight="true">
                    <HBox fx:id="kidsRecommendedRow" styleClass="movie-row" spacing="12"/>
                </ScrollPane>
            </VBox>

            <VBox styleClass="section" spacing="15">
                <HBox alignment="CENTER_LEFT" spacing="8" styleClass="section-header-row">
                    <Label text="🆕" styleClass="section-icon"/>
                    <Label text="Новинки" styleClass="section-title"/>
                </HBox>
                <ScrollPane styleClass="h-scroll" hbarPolicy="AS_NEEDED" vbarPolicy="NEVER"
                            fitToHeight="true">
                    <HBox fx:id="kidsLatestRow" styleClass="movie-row" spacing="12"/>
                </ScrollPane>
            </VBox>

            <VBox styleClass="section" spacing="15">
                <HBox alignment="CENTER_LEFT" spacing="8" styleClass="section-header-row">
                    <Label text="🎞" styleClass="section-icon"/>
                    <Label text="Фильмы" styleClass="section-title"/>
                </HBox>
                <ScrollPane styleClass="h-scroll" hbarPolicy="AS_NEEDED" vbarPolicy="NEVER"
                            fitToHeight="true">
                    <HBox fx:id="kidsFilmsRow" styleClass="movie-row" spacing="12"/>
                </ScrollPane>
            </VBox>

            <VBox styleClass="section" spacing="15">
                <HBox alignment="CENTER_LEFT" spacing="8" styleClass="section-header-row">
                    <Label text="📺" styleClass="section-icon"/>
                    <Label text="Сериалы" styleClass="section-title"/>
                </HBox>
                <ScrollPane styleClass="h-scroll" hbarPolicy="AS_NEEDED" vbarPolicy="NEVER"
                            fitToHeight="true">
                    <HBox fx:id="kidsSeriesRow" styleClass="movie-row" spacing="12"/>
                </ScrollPane>
            </VBox>

            <VBox styleClass="section" spacing="15">
                <HBox alignment="CENTER_LEFT" spacing="8" styleClass="section-header-row">
                    <Label text="🔥" styleClass="section-icon"/>
                    <Label text="Популярное" styleClass="section-title"/>
                </HBox>
                <ScrollPane styleClass="h-scroll" hbarPolicy="AS_NEEDED" vbarPolicy="NEVER"
                            fitToHeight="true">
                    <HBox fx:id="kidsPopularRow" styleClass="movie-row" spacing="12"/>
                </ScrollPane>
            </VBox>

        </VBox>

    </VBox>
</ScrollPane>
