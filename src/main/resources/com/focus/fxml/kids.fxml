<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.focus.controller.KidsController"
      styleClass="content-page">

    <!-- ШАПКА страницы -->
    <VBox styleClass="kids-page-header">
        <HBox alignment="CENTER_LEFT" spacing="16" styleClass="kids-header-row">
            <VBox spacing="2" HBox.hgrow="ALWAYS">
                <Label text="👶 Детям" styleClass="kids-page-title"/>
                <Label text="Безопасный контент для маленьких зрителей" styleClass="kids-page-subtitle"/>
            </VBox>
            <HBox spacing="10" alignment="CENTER_RIGHT">
                <TextField fx:id="kidsSearchField"
                           promptText="🔍  Поиск в детском..."
                           styleClass="kids-search-field"
                           prefWidth="260"/>
                <Button fx:id="kidsFilterBtn"
                        text="🎛 Фильтры"
                        onAction="#openKidsFilterPopup"
                        styleClass="kids-filter-btn"/>
            </HBox>
        </HBox>
    </VBox>

    <!-- РЕЗУЛЬТАТЫ ПОИСКА (скрыты по умолчанию) -->
    <VBox fx:id="kidsSearchSection" styleClass="kids-search-section"
          visible="false" managed="false">
        <HBox alignment="CENTER_LEFT" spacing="12" styleClass="search-results-header">
            <Label fx:id="kidsResultsLabel" text="Найдено: 0" styleClass="kids-results-label"/>
        </HBox>
        <FlowPane fx:id="kidsSearchGrid" hgap="12" vgap="16"
                  styleClass="kids-search-grid"/>
    </VBox>

    <!-- СЕКЦИИ (видны при отсутствии поиска) -->
    <ScrollPane fx:id="kidsMainScroll" styleClass="kids-scroll"
                fitToWidth="true" hbarPolicy="NEVER">
        <VBox fx:id="kidsSectionsBox" styleClass="kids-sections-box" spacing="0">

            <!-- ====== ВСЕ ДЕТСКОЕ ====== -->
            <VBox styleClass="kids-section">
                <HBox alignment="CENTER_LEFT" spacing="8" styleClass="section-header-row">
                    <Label text="🎪" styleClass="section-icon"/>
                    <Label text="Всё детское" styleClass="kids-section-title"/>
                </HBox>
                <ScrollPane styleClass="kids-h-scroll" hbarPolicy="AS_NEEDED" vbarPolicy="NEVER"
                            fitToHeight="true" prefHeight="235">
                    <HBox fx:id="kidsAllRow" styleClass="kids-movie-row" spacing="12"/>
                </ScrollPane>
            </VBox>

            <!-- ====== РЕКОМЕНДУЕМ (НОВАЯ СЕКЦИЯ) ====== -->
            <VBox styleClass="kids-section kids-section-accent">
                <HBox alignment="CENTER_LEFT" spacing="8" styleClass="section-header-row">
                    <Label text="⭐" styleClass="section-icon"/>
                    <Label text="Рекомендуем" styleClass="kids-section-title-green"/>
                </HBox>
                <ScrollPane styleClass="kids-h-scroll" hbarPolicy="AS_NEEDED" vbarPolicy="NEVER"
                            fitToHeight="true" prefHeight="235">
                    <HBox fx:id="kidsRecommendedRow" styleClass="kids-movie-row" spacing="12"/>
                </ScrollPane>
            </VBox>

            <!-- ====== ФИЛЬМЫ ====== -->
            <VBox styleClass="kids-section">
                <HBox alignment="CENTER_LEFT" spacing="8" styleClass="section-header-row">
                    <Label text="🎬" styleClass="section-icon"/>
                    <Label text="Фильмы" styleClass="kids-section-title"/>
                </HBox>
                <ScrollPane styleClass="kids-h-scroll" hbarPolicy="AS_NEEDED" vbarPolicy="NEVER"
                            fitToHeight="true" prefHeight="235">
                    <HBox fx:id="kidsFilmsRow" styleClass="kids-movie-row" spacing="12"/>
                </ScrollPane>
            </VBox>

            <!-- ====== СЕРИАЛЫ ====== -->
            <VBox styleClass="kids-section">
                <HBox alignment="CENTER_LEFT" spacing="8" styleClass="section-header-row">
                    <Label text="📺" styleClass="section-icon"/>
                    <Label text="Сериалы" styleClass="kids-section-title"/>
                </HBox>
                <ScrollPane styleClass="kids-h-scroll" hbarPolicy="AS_NEEDED" vbarPolicy="NEVER"
                            fitToHeight="true" prefHeight="235">
                    <HBox fx:id="kidsSeriesRow" styleClass="kids-movie-row" spacing="12"/>
                </ScrollPane>
            </VBox>

            <!-- ====== ПОПУЛЯРНОЕ ====== -->
            <VBox styleClass="kids-section">
                <HBox alignment="CENTER_LEFT" spacing="8" styleClass="section-header-row">
                    <Label text="🔥" styleClass="section-icon"/>
                    <Label text="Популярное" styleClass="kids-section-title"/>
                </HBox>
                <ScrollPane styleClass="kids-h-scroll" hbarPolicy="AS_NEEDED" vbarPolicy="NEVER"
                            fitToHeight="true" prefHeight="235">
                    <HBox fx:id="kidsPopularRow" styleClass="kids-movie-row" spacing="12"/>
                </ScrollPane>
            </VBox>

            <!-- ====== НОВИНКИ ====== -->
            <VBox styleClass="kids-section">
                <HBox alignment="CENTER_LEFT" spacing="8" styleClass="section-header-row">
                    <Label text="🆕" styleClass="section-icon"/>
                    <Label text="Новинки" styleClass="kids-section-title"/>
                </HBox>
                <ScrollPane styleClass="kids-h-scroll" hbarPolicy="AS_NEEDED" vbarPolicy="NEVER"
                            fitToHeight="true" prefHeight="235">
                    <HBox fx:id="kidsLatestRow" styleClass="kids-movie-row" spacing="12"/>
                </ScrollPane>
            </VBox>

        </VBox>
    </ScrollPane>

</VBox>