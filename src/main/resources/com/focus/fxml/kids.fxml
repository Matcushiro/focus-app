<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>

<ScrollPane fitToWidth="true"
            styleClass="main-scroll kids-scroll"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.focus.controller.KidsController">

    <VBox styleClass="home-content kids-content" spacing="0">

        <!-- ===== ПОИСК (красивый детский блок, без баннера) ===== -->
        <VBox styleClass="search-hero-block kids-search-hero" spacing="14">
            <HBox spacing="12" alignment="CENTER_LEFT">
                <Label text="👶" styleClass="kids-hero-icon"/>
                <VBox spacing="4">
                    <Label text="Детский раздел" styleClass="page-hero-title kids-hero-title"/>
                    <Label text="Мультфильмы, сказки и познавательные программы" styleClass="page-hero-sub kids-hero-sub"/>
                </VBox>
            </HBox>
            <HBox spacing="12" alignment="CENTER_LEFT" styleClass="search-bar-hero kids-search-hero-bar">
                <HBox styleClass="search-input-wrapper kids-search-input-wrapper" HBox.hgrow="ALWAYS">
                    <Label text="🔍" styleClass="search-icon-label"/>
                    <TextField fx:id="kidsSearchField"
                               promptText="Поиск мультфильмов и сказок..."
                               styleClass="search-input-hero kids-search-input-hero"
                               HBox.hgrow="ALWAYS"/>
                </HBox>
                <Button fx:id="kidsFilterBtn"
                        text="🎛 Фильтры"
                        styleClass="filter-btn-hero kids-filter-btn"
                        onAction="#openKidsFilterPopup"/>
                <Label fx:id="kidsResultsLabel" styleClass="results-label kids-results-label"/>
            </HBox>
        </VBox>

        <!-- ===== СЕКЦИИ (скрываются при поиске) ===== -->
        <VBox fx:id="kidsSectionsBox" styleClass="sections-wrapper" spacing="40">

            <!-- Все детские -->
            <VBox styleClass="section" spacing="15">
                <Label text="🌈 ВСЁ ДЕТСКОЕ" styleClass="section-title kids-section-title"/>
                <ScrollPane styleClass="h-scroll" fitToHeight="true">
                    <HBox fx:id="kidsAllRow" spacing="12" styleClass="movie-row"/>
                </ScrollPane>
            </VBox>

            <!-- Детские фильмы -->
            <VBox styleClass="section" spacing="15">
                <Label text="🎬 МУЛЬТФИЛЬМЫ И ФИЛЬМЫ" styleClass="section-title kids-section-title"/>
                <ScrollPane styleClass="h-scroll" fitToHeight="true">
                    <HBox fx:id="kidsFilmsRow" spacing="12" styleClass="movie-row"/>
                </ScrollPane>
            </VBox>

            <!-- Детские сериалы -->
            <VBox styleClass="section" spacing="15">
                <Label text="📺 МУЛЬТСЕРИАЛЫ И СЕРИАЛЫ" styleClass="section-title kids-section-title"/>
                <ScrollPane styleClass="h-scroll" fitToHeight="true">
                    <HBox fx:id="kidsSeriesRow" spacing="12" styleClass="movie-row"/>
                </ScrollPane>
            </VBox>

            <!-- Популярные детские -->
            <VBox styleClass="section" spacing="15">
                <Label text="🔥 ПОПУЛЯРНОЕ" styleClass="section-title kids-section-title"/>
                <ScrollPane styleClass="h-scroll" fitToHeight="true">
                    <HBox fx:id="kidsPopularRow" spacing="12" styleClass="movie-row"/>
                </ScrollPane>
            </VBox>

            <!-- Новинки детских -->
            <VBox styleClass="section" spacing="15">
                <Label text="🆕 НОВИНКИ" styleClass="section-title kids-section-title"/>
                <ScrollPane styleClass="h-scroll" fitToHeight="true">
                    <HBox fx:id="kidsLatestRow" spacing="12" styleClass="movie-row"/>
                </ScrollPane>
            </VBox>

        </VBox>

        <!-- ===== ГРИД ДЛЯ ПОИСКА (виден только при поиске) ===== -->
        <VBox fx:id="kidsSearchSection" visible="false" managed="false"
              styleClass="sections-wrapper" spacing="15">
            <FlowPane fx:id="kidsSearchGrid"
                      hgap="12" vgap="16"
                      styleClass="movies-grid kids-grid"/>
        </VBox>

    </VBox>
</ScrollPane>
