<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:id="rootPane"
            fx:controller="com.focus.controller.MainController"
            styleClass="root-pane">

    <top>
        <HBox styleClass="navbar"
              alignment="CENTER_LEFT"
              spacing="20">

            <!-- Логотип -->
            <ImageView fx:id="logoImage"
                       fitWidth="120"
                       fitHeight="40"
                       preserveRatio="true"/>

            <!-- Навигация -->
            <Button text="Главная"
                    styleClass="nav-btn"
                    onAction="#goHome"/>
            <Button text="Фильмы"
                    styleClass="nav-btn"
                    onAction="#goMovies"/>
            <Button text="Сериалы"
                    styleClass="nav-btn"
                    onAction="#goSeries"/>
            <Button text="Детям"
                    styleClass="nav-btn"
                    onAction="#goKids"/>

            <!-- Растягиватель -->
            <Region HBox.hgrow="ALWAYS"/>

            <!-- Кнопка поиска -->
            <Button text="🔍"
                    styleClass="search-icon-btn"
                    onAction="#goSearch"/>

            <!-- Кнопка админа (скрыта по умолчанию) -->
            <Button fx:id="adminBtn"
                    text="⚙️ Админ"
                    styleClass="nav-btn"
                    onAction="#goAdmin"
                    visible="false"
                    managed="false"/>

            <!-- Кнопка профиля -->
            <Button fx:id="profileBtn"
                    text="Войти"
                    styleClass="profile-btn"
                    onAction="#goProfile"/>

        </HBox>
    </top>

    <center>
        <fx:include source="home.fxml"/>
    </center>

</BorderPane>