<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:id="rootPane"
            fx:controller="com.focus.controller.MainController"
            styleClass="root-pane">

    <top>
        <HBox styleClass="navbar"
              alignment="CENTER_LEFT"
              spacing="4">

            <ImageView fx:id="logoImage"
                       fitWidth="120"
                       fitHeight="40"
                       preserveRatio="true"/>

            <Button fx:id="homeBtn"
                    text="Главная"
                    styleClass="nav-btn-active"
                    onAction="#goHome"/>
            <Button fx:id="moviesBtn"
                    text="Фильмы"
                    styleClass="nav-btn"
                    onAction="#goMovies"/>
            <Button fx:id="seriesBtn"
                    text="Сериалы"
                    styleClass="nav-btn"
                    onAction="#goSeries"/>
            <Button fx:id="kidsBtn"
                    text="Детям"
                    styleClass="nav-btn"
                    onAction="#goKids"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Button text="🔍"
                    styleClass="search-icon-btn"
                    onAction="#goSearch"/>

            <Button fx:id="adminBtn"
                    text="⚙️ Админ"
                    styleClass="nav-btn"
                    onAction="#goAdmin"
                    visible="false"
                    managed="false"/>

            <Button fx:id="profileBtn"
                    text="Войти"
                    styleClass="profile-btn"
                    onAction="#goProfile"/>

        </HBox>
    </top>

    <center>
        <fx:include source="home.fxml"/>
    </center>

</BorderPane>
