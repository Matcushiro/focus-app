<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.focus.controller.AdminController"
            styleClass="root-pane">

    <top>
        <Label text="⚙️ Управление контентом"
               styleClass="admin-title"
               BorderPane.alignment="CENTER"/>
    </top>

    <center>
        <HBox spacing="20" styleClass="admin-content">

            <VBox spacing="10" HBox.hgrow="ALWAYS">
                <Label text="Все фильмы"
                       styleClass="section-title"/>
                <ListView fx:id="moviesList"
                          VBox.vgrow="ALWAYS"
                          styleClass="admin-list"/>
                <HBox spacing="10">
                    <Button text="✏️ Редактировать"
                            styleClass="admin-btn"
                            onAction="#editMovie"/>
                    <Button text="🗑️ Удалить"
                            styleClass="admin-btn-danger"
                            onAction="#deleteMovie"/>
                </HBox>
            </VBox>

            <ScrollPane fitToWidth="true"
                        prefWidth="450">
                <VBox spacing="12"
                      styleClass="admin-form">

                    <Label text="Добавить / Редактировать"
                           styleClass="form-title"/>

                    <Label text="Название *"/>
                    <TextField fx:id="titleField"
                               promptText="Название"/>

                    <Label text="Описание"/>
                    <TextArea fx:id="descField"
                              promptText="Описание"
                              prefRowCount="3"
                              wrapText="true"/>

                    <Label text="Постер"/>
                    <HBox spacing="10"
                          alignment="CENTER_LEFT">
                        <TextField fx:id="posterField"
                                   promptText="Путь к постеру"
                                   HBox.hgrow="ALWAYS"/>
                        <Button text="📁"
                                onAction="#selectPoster"/>
                    </HBox>

                    <Label text="Баннер"/>
                    <HBox spacing="10"
                          alignment="CENTER_LEFT">
                        <TextField fx:id="bannerField"
                                   promptText="Путь к баннеру"
                                   HBox.hgrow="ALWAYS"/>
                        <Button text="📁"
                                onAction="#selectBanner"/>
                    </HBox>

                    <Label text="Видео файл"/>
                    <HBox spacing="10"
                          alignment="CENTER_LEFT">
                        <TextField fx:id="videoField"
                                   promptText="Путь к видео"
                                   HBox.hgrow="ALWAYS"/>
                        <Button text="📁"
                                onAction="#selectVideo"/>
                    </HBox>

                    <HBox spacing="10">
                        <VBox spacing="5"
                              HBox.hgrow="ALWAYS">
                            <Label text="Рейтинг"/>
                            <TextField fx:id="ratingField"
                                       promptText="8.5"/>
                        </VBox>
                        <VBox spacing="5"
                              HBox.hgrow="ALWAYS">
                            <Label text="Год"/>
                            <TextField fx:id="yearField"
                                       promptText="2024"/>
                        </VBox>
                        <VBox spacing="5"
                              HBox.hgrow="ALWAYS">
                            <Label text="Мин"/>
                            <TextField fx:id="durationField"
                                       promptText="120"/>
                        </VBox>
                    </HBox>

                    <Label text="Режиссёр"/>
                    <TextField fx:id="directorField"
                               promptText="Режиссёр"/>

                    <HBox spacing="10">
                        <VBox spacing="5"
                              HBox.hgrow="ALWAYS">
                            <Label text="Страна"/>
                            <TextField fx:id="countryField"
                                       promptText="Страна"/>
                        </VBox>
                        <VBox spacing="5"
                              HBox.hgrow="ALWAYS">
                            <Label text="Категория"/>
                            <ComboBox fx:id="categoryBox"
                                      prefWidth="150"/>
                        </VBox>
                    </HBox>

                    <Label text="Жанры"/>
                    <TextField fx:id="genresField"
                               promptText="Драма, Комедия"/>

                    <Label text="Разделы на главной"
                           styleClass="form-subtitle"/>

                    <GridPane hgap="20" vgap="8">
                        <CheckBox fx:id="nowPlayingCheck"
                                  text="Смотрите сейчас"
                                  GridPane.columnIndex="0"
                                  GridPane.rowIndex="0"/>
                        <CheckBox fx:id="latestCheck"
                                  text="Новинки"
                                  GridPane.columnIndex="1"
                                  GridPane.rowIndex="0"/>
                        <CheckBox fx:id="topRatedCheck"
                                  text="Высокий рейтинг"
                                  GridPane.columnIndex="0"
                                  GridPane.rowIndex="1"/>
                        <CheckBox fx:id="popularCheck"
                                  text="Невозможно оторваться"
                                  GridPane.columnIndex="1"
                                  GridPane.rowIndex="1"/>
                        <CheckBox fx:id="kidsCheck"
                                  text="Детский топ"
                                  GridPane.columnIndex="0"
                                  GridPane.rowIndex="2"/>
                        <CheckBox fx:id="eveningCheck"
                                  text="Фильм на вечер"
                                  GridPane.columnIndex="1"
                                  GridPane.rowIndex="2"/>
                        <CheckBox fx:id="turkishCheck"
                                  text="Турецкий топ"
                                  GridPane.columnIndex="0"
                                  GridPane.rowIndex="3"/>
                        <CheckBox fx:id="top10Check"
                                  text="Топ 10 для вас"
                                  GridPane.columnIndex="1"
                                  GridPane.rowIndex="3"/>
                        <CheckBox fx:id="featuredCheck"
                                  text="⭐ Баннер"
                                  GridPane.columnIndex="0"
                                  GridPane.rowIndex="4"/>
                    </GridPane>

                    <HBox spacing="10" alignment="CENTER">
                        <Button text="💾 Сохранить"
                                styleClass="save-btn"
                                onAction="#saveMovie"/>
                        <Button text="🔄 Очистить"
                                styleClass="clear-btn"
                                onAction="#clearForm"/>
                    </HBox>

                </VBox>
            </ScrollPane>

        </HBox>
    </center>

</BorderPane>