<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.focus.controller.AdminController"
            styleClass="admin-page">

    <!-- ===== ЛЕВАЯ ПАНЕЛЬ: форма добавления ===== -->
    <left>
        <ScrollPane fitToWidth="true" styleClass="admin-scroll"
                    prefWidth="420" minWidth="380">
            <VBox styleClass="admin-form-panel" spacing="14">

                <Label text="📽 Управление контентом" styleClass="admin-section-title"/>

                <!-- Тип контента -->
                <VBox spacing="5">
                    <Label text="Тип контента" styleClass="admin-field-label"/>
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <ComboBox fx:id="categoryBox" styleClass="admin-combo"
                                  prefWidth="160"/>
                        <CheckBox fx:id="isKidsContentCheck"
                                  text="👶 Детский контент"
                                  styleClass="admin-check"/>
                    </HBox>
                    <Label text="Выберите Фильм или Сериал. Отметьте «Детский контент» если нужно."
                           styleClass="admin-hint"/>
                </VBox>

                <Separator styleClass="admin-sep"/>

                <!-- Название -->
                <VBox spacing="5">
                    <Label text="Название *" styleClass="admin-field-label"/>
                    <TextField fx:id="titleField" promptText="Введите название"
                               styleClass="admin-field"/>
                </VBox>

                <!-- Описание -->
                <VBox spacing="5">
                    <Label text="Описание" styleClass="admin-field-label"/>
                    <TextArea fx:id="descField" promptText="Краткое описание..."
                              styleClass="admin-textarea" prefRowCount="3" wrapText="true"/>
                </VBox>

                <!-- Жанры — мультивыбор тегами -->
                <VBox spacing="8">
                    <Label text="Жанры * (можно выбрать несколько)" styleClass="admin-field-label"/>
                    <FlowPane fx:id="genresPane" hgap="6" vgap="6"
                              styleClass="admin-genres-pane"/>
                    <Label text="Нажмите на жанр чтобы выбрать/снять выбор"
                           styleClass="admin-hint"/>
                </VBox>

                <Separator styleClass="admin-sep"/>

                <!-- Числовые поля -->
                <GridPane hgap="10" vgap="8">
                    <VBox GridPane.columnIndex="0" GridPane.rowIndex="0" spacing="5">
                        <Label text="Рейтинг (0-10)" styleClass="admin-field-label"/>
                        <TextField fx:id="ratingField" promptText="8.5"
                                   styleClass="admin-field-sm"/>
                    </VBox>
                    <VBox GridPane.columnIndex="1" GridPane.rowIndex="0" spacing="5">
                        <Label text="Год" styleClass="admin-field-label"/>
                        <TextField fx:id="yearField" promptText="2024"
                                   styleClass="admin-field-sm"/>
                    </VBox>
                    <VBox GridPane.columnIndex="2" GridPane.rowIndex="0" spacing="5">
                        <Label text="Длит. (мин)" styleClass="admin-field-label"/>
                        <TextField fx:id="durationField" promptText="120"
                                   styleClass="admin-field-sm"/>
                    </VBox>
                </GridPane>

                <GridPane hgap="10" vgap="8">
                    <VBox GridPane.columnIndex="0" GridPane.rowIndex="0" spacing="5">
                        <Label text="Режиссёр" styleClass="admin-field-label"/>
                        <TextField fx:id="directorField" promptText="Имя режиссёра"
                                   styleClass="admin-field"/>
                    </VBox>
                    <VBox GridPane.columnIndex="1" GridPane.rowIndex="0" spacing="5">
                        <Label text="Страна" styleClass="admin-field-label"/>
                        <TextField fx:id="countryField" promptText="Россия"
                                   styleClass="admin-field"/>
                    </VBox>
                </GridPane>

                <Separator styleClass="admin-sep"/>

                <!-- Медиафайлы -->
                <Label text="Медиафайлы" styleClass="admin-field-label"/>

                <HBox spacing="6" alignment="CENTER_LEFT">
                    <TextField fx:id="posterField" promptText="Путь к постеру"
                               styleClass="admin-field" HBox.hgrow="ALWAYS"/>
                    <Button text="📁" styleClass="admin-file-btn" onAction="#selectPoster"/>
                </HBox>
                <HBox spacing="6" alignment="CENTER_LEFT">
                    <TextField fx:id="bannerField" promptText="Путь к баннеру"
                               styleClass="admin-field" HBox.hgrow="ALWAYS"/>
                    <Button text="📁" styleClass="admin-file-btn" onAction="#selectBanner"/>
                </HBox>
                <HBox spacing="6" alignment="CENTER_LEFT">
                    <TextField fx:id="videoField" promptText="Путь к видео"
                               styleClass="admin-field" HBox.hgrow="ALWAYS"/>
                    <Button text="📁" styleClass="admin-file-btn" onAction="#selectVideo"/>
                </HBox>

                <Separator styleClass="admin-sep"/>

                <!-- Флаги отображения -->
                <Label text="Флаги отображения" styleClass="admin-field-label"/>
                <GridPane hgap="12" vgap="8">
                    <CheckBox fx:id="nowPlayingCheck" text="В эфире"
                              styleClass="admin-check"
                              GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <CheckBox fx:id="latestCheck" text="Новинка"
                              styleClass="admin-check"
                              GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                    <CheckBox fx:id="topRatedCheck" text="Топ оценок"
                              styleClass="admin-check"
                              GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <CheckBox fx:id="popularCheck" text="Популярное"
                              styleClass="admin-check"
                              GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                    <CheckBox fx:id="kidsCheck" text="Для детей"
                              styleClass="admin-check"
                              GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                    <CheckBox fx:id="eveningCheck" text="Вечернее"
                              styleClass="admin-check"
                              GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                    <CheckBox fx:id="turkishCheck" text="Турецкое"
                              styleClass="admin-check"
                              GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                    <CheckBox fx:id="top10Check" text="Топ 10"
                              styleClass="admin-check"
                              GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                    <CheckBox fx:id="featuredCheck" text="⭐ Избранное (баннер)"
                              styleClass="admin-check"
                              GridPane.columnIndex="0" GridPane.rowIndex="4"
                              GridPane.columnSpan="2"/>
                </GridPane>

                <Separator styleClass="admin-sep"/>

                <!-- Кнопки действий -->
                <HBox spacing="8">
                    <Button text="💾 Сохранить" styleClass="admin-btn-primary"
                            onAction="#saveMovie" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                    <Button text="✖ Очистить" styleClass="admin-btn-secondary"
                            onAction="#clearForm"/>
                </HBox>

            </VBox>
        </ScrollPane>
    </left>

    <!-- ===== ПРАВАЯ ПАНЕЛЬ: список контента ===== -->
    <center>
        <VBox styleClass="admin-list-panel" spacing="12">

            <Label text="📋 Список фильмов и сериалов" styleClass="admin-section-title"/>

            <ListView fx:id="moviesList" styleClass="admin-list" VBox.vgrow="ALWAYS"/>

            <HBox spacing="8">
                <Button text="✏ Редактировать" styleClass="admin-btn-edit"
                        onAction="#editMovie" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                <Button text="🗑 Удалить" styleClass="admin-btn-danger"
                        onAction="#deleteMovie" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
            </HBox>

        </VBox>
    </center>

</BorderPane>
