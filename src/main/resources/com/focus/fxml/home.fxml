<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>

<ScrollPane fitToWidth="true"
            styleClass="main-scroll"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.focus.controller.HomeController">

    <VBox styleClass="home-content" spacing="0">

        <!-- БАННЕР -->
        <StackPane fx:id="bannerPane"
                   styleClass="banner-pane">

            <!-- Фоновое изображение -->
            <ImageView fx:id="bannerImage"
                       styleClass="banner-bg"
                       preserveRatio="false"
                       fitHeight="400"/>

            <!-- Затемнение -->
            <Pane styleClass="banner-overlay"/>

            <!-- Контент баннера -->
            <HBox styleClass="banner-content"
                  alignment="BOTTOM_LEFT">

                <VBox styleClass="banner-info"
                      spacing="10"
                      alignment="BOTTOM_LEFT">

                    <!-- Название -->
                    <Label fx:id="bannerTitle"
                           styleClass="banner-title"
                           wrapText="true"
                           maxWidth="350"/>

                    <!-- Описание -->
                    <Label fx:id="bannerDesc"
                           styleClass="banner-desc"
                           wrapText="true"
                           maxWidth="350"/>

                    <!-- Рейтинг -->
                    <Label fx:id="bannerRating"
                           styleClass="banner-rating"/>

                    <!-- Кнопки -->
                    <HBox spacing="12"
                          alignment="CENTER_LEFT">
                        <Button text="СМОТРЕТЬ"
                                styleClass="watch-btn"
                                onAction="#watchFeatured"/>
                        <Button text="+ В список"
                                styleClass="list-btn"
                                onAction="#addToList"/>
                    </HBox>

                </VBox>

            </HBox>

        </StackPane>

        <!-- СЕКЦИИ -->
        <VBox styleClass="sections-wrapper" spacing="40">

            <!-- Смотрите сейчас -->
            <VBox styleClass="section" spacing="15">
                <Label text="СМОТРИТЕ СЕЙЧАС"
                       styleClass="section-title"/>

                <!-- Ряд 1 -->
                <HBox fx:id="nowPlayingRow"
                      spacing="12"
                      styleClass="movie-row-nowrap"/>

                <!-- Ряд 2 (продолжение) -->
                <HBox fx:id="nowPlayingRow2"
                      spacing="12"
                      styleClass="movie-row-nowrap"/>

            </VBox>

            <!-- Новинки -->
            <VBox styleClass="section" spacing="15">
                <Label text="НОВИНКИ"
                       styleClass="section-title"/>
                <ScrollPane styleClass="h-scroll"
                            fitToHeight="true">
                    <HBox fx:id="latestRow"
                          spacing="12"
                          styleClass="movie-row"/>
                </ScrollPane>
            </VBox>

            <!-- Высокий рейтинг -->
            <VBox styleClass="section" spacing="15">
                <Label text="ВЫСОКИЙ РЕЙТИНГ"
                       styleClass="section-title"/>
                <ScrollPane styleClass="h-scroll"
                            fitToHeight="true">
                    <HBox fx:id="topRatedRow"
                          spacing="12"
                          styleClass="movie-row"/>
                </ScrollPane>
            </VBox>

            <!-- Невозможно оторваться -->
            <VBox styleClass="section" spacing="15">
                <Label text="НЕВОЗМОЖНО ОТОРВАТЬСЯ"
                       styleClass="section-title"/>
                <ScrollPane styleClass="h-scroll"
                            fitToHeight="true">
                    <HBox fx:id="popularRow"
                          spacing="12"
                          styleClass="movie-row"/>
                </ScrollPane>
            </VBox>

            <!-- Детский топ -->
            <VBox styleClass="section" spacing="15">
                <Label text="ДЕТСКИЙ ТОП"
                       styleClass="section-title"/>
                <ScrollPane styleClass="h-scroll"
                            fitToHeight="true">
                    <HBox fx:id="kidsRow"
                          spacing="12"
                          styleClass="movie-row"/>
                </ScrollPane>
            </VBox>

            <!-- Фильм на вечер -->
            <VBox styleClass="section" spacing="15">
                <Label text="ФИЛЬМ НА ВЕЧЕР"
                       styleClass="section-title"/>
                <ScrollPane styleClass="h-scroll"
                            fitToHeight="true">
                    <HBox fx:id="eveningRow"
                          spacing="12"
                          styleClass="movie-row"/>
                </ScrollPane>
            </VBox>

            <!-- Турецкий топ -->
            <VBox styleClass="section" spacing="15">
                <Label text="ТУРЕЦКИЙ ТОП"
                       styleClass="section-title"/>
                <ScrollPane styleClass="h-scroll"
                            fitToHeight="true">
                    <HBox fx:id="turkishRow"
                          spacing="12"
                          styleClass="movie-row"/>
                </ScrollPane>
            </VBox>

            <!-- Топ 10 -->
            <VBox styleClass="section" spacing="15">
                <Label text="ТОП 10 ДЛЯ ВАС"
                       styleClass="section-title"/>
                <ScrollPane styleClass="h-scroll"
                            fitToHeight="true">
                    <HBox fx:id="top10Row"
                          spacing="12"
                          styleClass="movie-row"/>
                </ScrollPane>
            </VBox>

        </VBox>
    </VBox>
</ScrollPane>