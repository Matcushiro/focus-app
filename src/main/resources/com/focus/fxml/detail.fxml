<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>

<!--
    detail.fxml — страница детали фильма/сериала

    ИСПРАВЛЕНИЯ:
    - Добавлен fx:id="favoriteBtn" для динамического обновления текста (В список / ✅ В избранном)
    - Кнопка "Назад" теперь корректно работает через goBack()
-->
<ScrollPane fitToWidth="true"
            styleClass="main-scroll"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.focus.controller.DetailController">

    <VBox styleClass="detail-wrapper" spacing="0">

        <!-- Баннер / фон -->
        <StackPane styleClass="detail-banner">
            <ImageView fx:id="backdropImage"
                       preserveRatio="false"
                       styleClass="detail-backdrop"/>
            <Pane styleClass="detail-overlay"/>
            <VBox alignment="TOP_LEFT"
                  styleClass="detail-back-box">
                <Button text="← Назад"
                        styleClass="back-btn"
                        onAction="#goBack"/>
            </VBox>
        </StackPane>

        <!-- Основной контент -->
        <HBox styleClass="detail-content" spacing="30">

            <!-- Левая колонка: постер + кнопки -->
            <VBox spacing="12" alignment="TOP_CENTER">
                <ImageView fx:id="posterImage"
                           fitWidth="220"
                           fitHeight="330"
                           preserveRatio="false"
                           styleClass="detail-poster"/>
                <Button text="▶  Смотреть"
                        styleClass="watch-btn"
                        prefWidth="220"
                        onAction="#watchMovie"/>
                <!-- ИСПРАВЛЕНИЕ: добавлен fx:id для смены текста -->
                <Button fx:id="favoriteBtn"
                        text="+ В список"
                        styleClass="list-btn"
                        prefWidth="220"
                        onAction="#addToFavorites"/>
            </VBox>

            <!-- Правая колонка: информация -->
            <VBox spacing="12" HBox.hgrow="ALWAYS">

                <!-- Название -->
                <Label fx:id="titleLabel"
                       styleClass="detail-title"
                       wrapText="true"/>

                <!-- Рейтинг, год, длительность, категория -->
                <HBox spacing="20" alignment="CENTER_LEFT">
                    <Label fx:id="ratingLabel"   styleClass="detail-rating"/>
                    <Label fx:id="yearLabel"      styleClass="detail-info-label"/>
                    <Label fx:id="durationLabel"  styleClass="detail-info-label"/>
                    <Label fx:id="categoryLabel"  styleClass="detail-category"/>
                </HBox>

                <!-- Жанры (динамически, через genresBox) -->
                <HBox fx:id="genresBox"
                      spacing="8"
                      alignment="CENTER_LEFT"/>

                <!-- Описание -->
                <Label text="Описание"
                       styleClass="detail-section-title"/>
                <Label fx:id="descLabel"
                       styleClass="detail-desc"
                       wrapText="true"/>

                <!-- Доп. информация -->
                <VBox styleClass="detail-info-box" spacing="8">
                    <HBox spacing="10">
                        <Label text="Режиссёр:" styleClass="info-key"/>
                        <Label fx:id="directorLabel" styleClass="info-value"/>
                    </HBox>
                    <HBox spacing="10">
                        <Label text="Страна:"    styleClass="info-key"/>
                        <Label fx:id="countryLabel" styleClass="info-value"/>
                    </HBox>
                    <HBox spacing="10">
                        <Label text="Жанр:"      styleClass="info-key"/>
                        <Label fx:id="genresLabel" styleClass="info-value" wrapText="true"/>
                    </HBox>
                </VBox>

            </VBox>

        </HBox>
    </VBox>
</ScrollPane>
